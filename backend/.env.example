MONGO_URL=mongodb://localhost:27017
DB_NAME=pixelshrink
CORS_ORIGINS=*

# --- Hugging Face (primary image generation provider) ---
# Get a free token at https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=hf_your_api_key_here
HUGGING_FACE_MODEL=stabilityai/stable-diffusion-2-1

# --- Together AI (optional fallback provider) ---
# Get a free API key at https://api.together.xyz
# Uses FLUX.1-schnell-Free by default (no credit card required for free tier)
# TOGETHER_API_KEY=
# TOGETHER_MODEL=black-forest-labs/FLUX.1-schnell-Free

# --- Pollinations.ai (free automatic fallback, no API key required) ---
# Pollinations is used automatically when HF/Together fail or are not configured.
# Set to "false" to disable.
POLLINATIONS_ENABLED=true

# --- Rate limiting & performance ---
AI_IMAGE_RATE_LIMIT=5
AI_IMAGE_RATE_LIMIT_WINDOW_SECONDS=60
AI_IMAGE_CACHE_TTL_SECONDS=600
AI_IMAGE_REQUEST_TIMEOUT_SECONDS=60
